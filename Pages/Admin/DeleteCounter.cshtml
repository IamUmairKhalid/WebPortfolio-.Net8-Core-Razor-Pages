@page
@model ResumeWebApp.Pages.Admin.DeleteCounterModel

@{
    ViewData["Title"] = "DeleteCounter";
}
<div class="row justify-content-center">
    <div class="col-md-8 justify-content-center">
        <h2>Delete Counter</h2>
        <h5>Are you sure you want to delete this?</h5>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Counter.Title)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Counter.Title)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Counter.Number)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Counter.Number)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Counter.Icon)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Counter.Icon)
        </dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="Counter.Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-page="./ShowCounter" class="btn btn-outline-secondary">Back to List</a>
    </form>
    </div>
</div>
