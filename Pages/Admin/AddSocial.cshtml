@page
@model ResumeWebApp.Pages.Admin.AddSocialModel

@{
    ViewData["Title"] = "AddSocial";
}
<div class="row justify-content-center">
    <div class="col-md-8 justify-content-center">

        <h2>AddSocial</h2>
        <hr />
        <form method="post">
            
            <div class="form-group">
                <label asp-for="Social.Fb" class="control-label"></label>
                <input asp-for="Social.Fb" class="form-control" />
                <span asp-validation-for="Social.Fb" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Social.Twitter" class="control-label"></label>
                <input asp-for="Social.Twitter" class="form-control" />
                <span asp-validation-for="Social.Twitter" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Social.Instagram" class="control-label"></label>
                <input asp-for="Social.Instagram" class="form-control" />
                <span asp-validation-for="Social.Instagram" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Social.Linkedin" class="control-label"></label>
                <input asp-for="Social.Linkedin" class="form-control" />
                <span asp-validation-for="Social.Linkedin" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Social.Skype" class="control-label"></label>
                <input asp-for="Social.Skype" class="form-control" />
                <span asp-validation-for="Social.Skype" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="ShowSocial">Back to List</a>
</div>
