@page
@model ResumeWebApp.Pages.Admin.UpdateSkillModel

@{
    ViewData["Title"] = "UpdateSkill";
}





<div class="row justify-content-center">
    <div class="col-md-8 justify-content-center">
        <h1>UpdateSkill</h1>
        <hr />
        <form method="post">
            
            <input type="hidden" asp-for="Skill.Id" />
            <div class="form-group">
                <label asp-for="Skill.Name" class="control-label"></label>
                <input asp-for="Skill.Name" class="form-control" />
                <span asp-validation-for="Skill.Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Skill.Number" class="control-label"></label>
                <input asp-for="Skill.Number" class="form-control" />
                <span asp-validation-for="Skill.Number" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="SaveChanges" class="btn btn-primary" /> |
                <a asp-page="./ShowSkill" class="btn btn-outline-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

