@page
@model ResumeWebApp.Pages.Admin.UpdateTestimonialModel

@{
    ViewData["Title"] = "UpdateTestimonial";
}
<div class="row justify-content-center">
    <div class="col-md-8 justify-content-center">
<h2>UpdateTestimonial</h2>
<hr />
        <form method="post" enctype="multipart/form-data">
            
            <input type="hidden" asp-for="Testimonial.Id" />
            <div class="form-group">
                <label asp-for="Testimonial.Name" class="control-label"></label>
                <input asp-for="Testimonial.Name" class="form-control" />
                <span asp-validation-for="Testimonial.Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Testimonial.Review" class="control-label"></label>
                <input asp-for="Testimonial.Review" class="form-control" />
                <span asp-validation-for="Testimonial.Review" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Testimonial.Designation" class="control-label"></label>
                <input asp-for="Testimonial.Designation" class="form-control" />
                <span asp-validation-for="Testimonial.Designation" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label">Image Name</label>
                <input asp-for="Testimonial.Image" readonly class="form-control" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Photo</label>
                <input asp-for="Testimonial.Photo" class="form-control" />
            </div>
            <div class="form-group mt-3">
                <input type="submit" value="Update" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>
<div>
    <a asp-page="./ShowTestimonial" class="btn btn-outline-secondary">Back to List</a>
</div>
    
