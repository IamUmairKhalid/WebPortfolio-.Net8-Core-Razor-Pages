@page
@model ResumeWebApp.Pages.Admin.ShowEducationModel
@{
}
<div class="row justify-content-center">

    <div class="col-md-10 justify-content-center">
        <h2>
            Educational Details
        </h2>

        <table class="table table-hover">
            <thead>
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">DegreeTitle</th>
                    <th scope="col">DegreeSession</th>
                    <th scope="col">InstituteName</th>
                    <th scope="col">Description</th>
                    <th scope="col" colspan="2">Options</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.edu)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.DegreeTitle</td>
                        <td>@item.DegreeSession</td>
                        <td>@item.InstituteName</td>
                        <td>@item.Des</td>
                        <td>
                            <a class="btn btn-success" asp-page="UpdateEducation" asp-route-id="@item.Id">Update</a>
                        </td>
                        <td>
                            <a class="btn btn-danger" asp-page-handler="Delete" asp-route-id="@item.Id">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

</div>