@page
@model ResumeWebApp.Pages.Admin.TestimonialDetailModel

@{
    ViewData["Title"] = "TestimonialDetail";
}

<div class="row justify-content-center">

    <div class="col-md-6 justify-content-center">
        <h2>TestimonialDetail</h2>
        <form class="row g-3" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Testimonial.Id" />
            <div class="col-md-6">
                <label class="form-label">Name</label>
                <input asp-for="Testimonial.Name" class="form-control" />
                <input asp-for="Testimonial.Id" hidden />
            </div>
            <div class="col-md-6">
                <label class="form-label">Review</label>
                <input asp-for="Testimonial.Review" class="form-control" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Designation</label>
                <input asp-for="Testimonial.Designation" class="form-control" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Image Name</label>
                <input asp-for="Testimonial.Image" readonly class="form-control" />
            </div>
            <div class="col-md-12 mt-3">
                <a asp-page="./ShowTestimonial" class="btn btn-outline-secondary">Back to List</a> |
                <a asp-page="./UpdateTestimonial" asp-route-id="@Model.Testimonial.Id" class="btn btn-outline-success">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil-square" viewBox="0 0 16 16">
                        <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z" />
                        <path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z" />
                    </svg>
                </a>
            </div>

        </form>
    </div>
    <div class="col-md-4 justify-content-center ">
        <img src="~/images/@Model.Testimonial.Image" style="border-radius:200px; left: 65px; margin-left: 65px; height:200px; width:200px"  class="mt-5 " />
    </div>
</div>
