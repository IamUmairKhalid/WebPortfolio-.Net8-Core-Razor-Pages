@page
@model ResumeWebApp.Pages.Admin.DeleteContactUsModel

@{
    ViewData["Title"] = "DeleteContactUs";
}
<div class="row justify-content-center">
    <div class="col-md-8 justify-content-center">
        <h2>Delete Contact</h2>
        <h5>Are you sure you want to delete this?</h5>
        <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ContactUs.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ContactUs.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ContactUs.Email)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ContactUs.Email)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ContactUs.Subject)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ContactUs.Subject)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ContactUs.Message)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ContactUs.Message)
        </dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="ContactUs.Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-page="./ShowContactUs" class="btn btn-outline-secondary">Back to List</a>
    </form>
</div>
</div>